{
    "name": "babelforge/babelchrome-markdown-viewer-module",
    "description": "BabelChrome module for rendering Markdown and Mermaid documents.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "BabelForge\\BabelChromeMarkdownViewerModule\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BabelForge\\BabelChromeMarkdownViewerModule\\Tests\\": "tests/",
            "BabelForge\\BabelChrome\\LocalViewer\\": "tests/LocalViewer/"
        }
    },
    "require": {
        "babelforge/babel-chrome-viewer-kit": "dev-main",
        "php": ">=8.4",
        "league/commonmark": "^2.7",
        "symfony/http-foundation": "^8.0",
        "twig/twig": "^3.21"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/babelforge/babel-chrome-viewer-kit.git"
        }
    ],
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.5",
        "sensiolabs/typescript-bundle": "^0.2.2",
        "symfony/asset": "^8.0",
        "symfony/asset-mapper": "^8.0",
        "symfony/flex": "^2.8",
        "symfony/framework-bundle": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "extra": {
        "symfony": {
            "endpoint": [
                "https://api.github.com/repos/babelforge/babelforge-flex-recipes/contents/index.json",
                "flex://defaults"
            ]
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=512M",
        "qa": [
            "@cs",
            "@analyse",
            "@test"
        ]
    }
}
